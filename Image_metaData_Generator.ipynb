# Function to convert GPS coordinates to decimal degrees
def convert_to_degrees(value):
    """Convert GPS coordinates to decimal degrees."""
    try:
        d = float(value[0][0]) / float(value[0][1])
        m = float(value[1][0]) / float(value[1][1])
        s = float(value[2][0]) / float(value[2][1])
        return d + (m / 60.0) + (s / 3600.0)
    except:
        return None

# Function to extract GPS info using exifread (more robust)
def extract_gps_exifread(img_path):
    """Extract GPS info using exifread library."""
    with open(img_path, 'rb') as f:
        tags = exifread.process_file(f)

        lat_tag = tags.get('GPS GPSLatitude')
        lat_ref = tags.get('GPS GPSLatitudeRef')
        lon_tag = tags.get('GPS GPSLongitude')
        lon_ref = tags.get('GPS GPSLongitudeRef')

        if lat_tag and lon_tag and lat_ref and lon_ref:
            try:
                # Convert to decimal degrees
                lat_values = [float(x.num) / float(x.den) for x in lat_tag.values]
                lon_values = [float(x.num) / float(x.den) for x in lon_tag.values]

                lat = lat_values[0] + lat_values[1]/60 + lat_values[2]/3600
                lon = lon_values[0] + lon_values[1]/60 + lon_values[2]/3600

                if str(lat_ref) == 'S':
                    lat = -lat
                if str(lon_ref) == 'W':
                    lon = -lon

                return {'latitude': lat, 'longitude': lon}
            except:
                return None
    return None

# Function to extract all metadata using exifread
def extract_all_metadata(img_path):
    """Extract all metadata using exifread."""
    metadata = {}
    with open(img_path, 'rb') as f:
        tags = exifread.process_file(f)

        # Map of interesting tags
        interesting_tags = {
            'Image Make': 'Camera Make',
            'Image Model': 'Camera Model',
            'EXIF DateTimeOriginal': 'Date/Time Original',
            'EXIF DateTimeDigitized': 'Date/Time Digitized',
            'EXIF ExposureTime': 'Exposure Time',
            'EXIF FNumber': 'Aperture',
            'EXIF ISOSpeedRatings': 'ISO',
            'EXIF FocalLength': 'Focal Length',
            'Image Software': 'Software',
            'EXIF LensModel': 'Lens Model',
            'GPS GPSLatitude': 'GPS Latitude',
            'GPS GPSLongitude': 'GPS Longitude',
        }

        for key, value in tags.items():
            if key in interesting_tags:
                metadata[interesting_tags[key]] = str(value)

    return metadata

# Function to download a sample GPS-tagged image
def download_sample_image():
    """Download a sample image with GPS data for testing."""
    # URL of a sample image with GPS data (CC0 license)
    image_urls = [
        "https://raw.githubusercontent.com/ianare/exif-samples/master/jpg/gps/DSCN0010.jpg",
        "https://github.com/ianare/exif-samples/raw/master/jpg/gps/IMG_20181127_130954.jpg"
    ]

    for url in image_urls:
        try:
            response = requests.get(url, timeout=10)
            if response.status_code == 200:
                return BytesIO(response.content)
        except:
            continue
    return None

# Function to get location name from coordinates
def get_location_name(lat, lon):
    """Get location name from coordinates using reverse geocoding."""
    try:
        result = rg.search((lat, lon))[0]
        return f"{result['name']}, {result['admin1']}, {result['cc']}"
    except:
        return "Unknown location"

# Function to create map
def create_map(lat, lon, location_name):
    """Create an interactive map with the GPS location."""
    # Create map centered at the GPS location
    m = folium.Map(location=[lat, lon], zoom_start=15)

    # Add marker
    folium.Marker(
        [lat, lon],
        popup=f'📍 {location_name}<br>Lat: {lat:.6f}<br>Lon: {lon:.6f}',
        tooltip='Click for details',
        icon=folium.Icon(color='red', icon='info-sign')
    ).add_to(m)

    # Add a circle to highlight the area
    folium.Circle(
        [lat, lon],
        radius=50,
        color='red',
        fill=True,
        popup='Location'
    ).add_to(m)

    # Add fullscreen button
    folium.plugins.Fullscreen().add_to(m)

    return m

