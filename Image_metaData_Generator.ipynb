# Function to process image
def process_image(image_data, filename):
    """Process uploaded image and display metadata."""
    with image_output:
        clear_output(wait=True)

    with metadata_output:
        clear_output(wait=True)

    with map_output:
        clear_output(wait=True)

    with status_output:
        clear_output()
        print(f"✅ Processing: {filename}")

    try:
        # Read and display image
        image = Image.open(io.BytesIO(image_data))

        with image_output:
            print(f"📁 Filename: {filename}")
            print(f"📏 Dimensions: {image.size[0]} x {image.size[1]} pixels")
            print(f"🎨 Color Mode: {image.mode}")
            print(f"💾 Format: {image.format}")
            print("-" * 30)
            display(image)

        # Save temporarily for metadata extraction
        temp_path = f"/tmp/{filename}"
        image.save(temp_path)

        # Extract metadata
        metadata = extract_all_metadata(temp_path)

        with metadata_output:
            print("📊 METADATA")
            print("=" * 30)

            if metadata:
                for key, value in metadata.items():
                    print(f"{key}: {value}")
            else:
                print("❌ No metadata found in this image")

            print("\n" + "=" * 30)
            print("ℹ️ Tips for GPS data:")
            print("• Photos from smartphones usually have GPS")
            print("• Enable location services when taking photos")
            print("• Try the 'Load Sample GPS Image' button")

        # Extract GPS coordinates using both methods
        gps_coords = extract_gps_exifread(temp_path)

        # Try piexif if exifread fails
        if not gps_coords:
            try:
                exif_dict = piexif.load(temp_path)
                gps_coords = extract_gps_info(exif_dict) if 'GPS' in exif_dict else None
            except:
                pass

        with map_output:
            if gps_coords:
                lat = gps_coords['latitude']
                lon = gps_coords['longitude']
                location_name = get_location_name(lat, lon)

                print("📍 GPS LOCATION FOUND")
                print("=" * 30)
                print(f"Latitude: {lat:.6f}")
                print(f"Longitude: {lon:.6f}")
                print(f"Location: {location_name}")
                print("\n🗺️ INTERACTIVE MAP")
                print("=" * 30)
                print("• Use + and - to zoom")
                print("• Click marker for details")
                print("• Use fullscreen button for larger view")

                # Create and display map
                m = create_map(lat, lon, location_name)
                display(m)
            else:
                print("❌ NO GPS DATA FOUND")
                print("=" * 30)
                print("This image doesn't contain GPS coordinates.")
                print("\n📌 Possible reasons:")
                print("• Location services were disabled")
                print("• Image was edited/saved without GPS")
                print("• Image is from a non-GPS camera")
                print("\n💡 Try the 'Load Sample GPS Image' button")

        # Clean up
        if os.path.exists(temp_path):
            os.remove(temp_path)

    except Exception as e:
        with status_output:
            clear_output()
            print(f"❌ Error: {str(e)}")

# Function to handle sample image
def load_sample_image(b):
    """Load and process a sample GPS-tagged image."""
    with status_output:
        clear_output()
        print("⏳ Downloading sample GPS image...")

    sample_image = download_sample_image()

    if sample_image:
        process_image(sample_image.getvalue(), "sample_gps_image.jpg")
    else:
        with status_output:
            clear_output()
            print("❌ Could not download sample image. Please upload your own image.")

# Handle upload
def on_upload_change(change):
    if upload_button.value:
        for filename, file_info in upload_button.value.items():
            process_image(file_info['content'], filename)

# Attach event handlers
upload_button.observe(on_upload_change, names='value')
sample_button.on_click(load_sample_image)

